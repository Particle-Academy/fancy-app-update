{
  "name": "@particle-academy/fancy-app-update",
  "version": "0.1.0",
  "description": "Framework-agnostic 'a new version is available — refresh' detector for any React app. Detect a redeploy (changed build) while the page is open and prompt a refresh. No Inertia, no PHP, no backend required — bring your own API, a version string, or just poll the page's ETag.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Particle-Academy/fancy-app-update.git"
  },
  "homepage": "https://github.com/Particle-Academy/fancy-app-update#readme",
  "bugs": "https://github.com/Particle-Academy/fancy-app-update/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsup"
  },
  "keywords": [
    "react",
    "version",
    "update",
    "deploy",
    "refresh",
    "new-version",
    "service-worker-alternative",
    "etag",
    "fancy",
    "particle-academy"
  ],
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
